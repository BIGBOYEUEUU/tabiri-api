# ── Tabiri API Environment Variables ────────────────────────────
# Copy this to .env and fill in real values
# NEVER commit .env to git

# Server
PORT=8080
ENVIRONMENT=development   # development | production

# Database (Docker Compose default)
DATABASE_URL=postgres://tabiri:tabiri@localhost:5432/tabiri?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate a strong random secret for production
# openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRY_HOURS=720        # 30 days
REFRESH_EXPIRY_HOURS=2160   # 90 days

# M-Pesa Daraja API
# Get these from https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379                           # sandbox shortcode
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://api.tabiri.africa/v1/mpesa/callback
MPESA_B2C_INITIATOR=your_initiator_name
MPESA_B2C_PASSWORD=your_b2c_security_credential
MPESA_ENV=sandbox    # sandbox | production

# Smile Identity (KYC)
# Get these from https://docs.smileidentity.com
SMILE_PARTNER_ID=your_partner_id
SMILE_API_KEY=your_api_key

# Platform rates (defaults shown — adjust per GRA licence terms)
PLATFORM_FEE_RATE=0.035    # 3.5%
MIN_TRADE_KES=50
EXCISE_DUTY_RATE=0.05      # 5% (Finance Act 2025)
WITHDRAWAL_TAX_RATE=0.05   # 5%
